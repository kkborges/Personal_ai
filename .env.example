# ═══════════════════════════════════════════════════════════════════════════
# Personal AI Mobile — Variáveis de Ambiente
# Copie para .env e preencha com seus valores
# ═══════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=production                          # development | production | testing
SECRET_KEY=mude-para-uma-chave-aleatoria-de-32-caracteres
PORT=8765
LANGUAGE=pt-BR
DEBUG=false

# ── Banco de Dados ────────────────────────────────────────────────────────────
# Opção 1: SQLite (desenvolvimento / instalação local simples)
DATABASE_URL=sqlite+aiosqlite:///./data/mobile_ai.db

# Opção 2: PostgreSQL (produção / Ubuntu Server / Docker)
# DATABASE_URL=postgresql+asyncpg://personal_ai:senha@localhost:5432/personal_ai
# POSTGRES_DB=personal_ai
# POSTGRES_USER=personal_ai
# POSTGRES_PASSWORD=senha_segura_aqui

# ── Redis + Celery (deixe em branco para usar APScheduler local) ─────────────
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Provedores de IA ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
GENSPARK_API_KEY=...
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_PROVIDER=openai                    # openai | anthropic | gemini | ollama
DEFAULT_MODEL=gpt-4o-mini
FALLBACK_PROVIDER=ollama
AUTONOMY_LEVEL=balanced                    # passive | balanced | proactive

# ── Voz ──────────────────────────────────────────────────────────────────────
TTS_BACKEND=edge-tts                       # edge-tts | openai | piper
TTS_VOICE=pt-BR-FranciscaNeural
TTS_SPEED=1.0
STT_BACKEND=whisper                        # whisper | google | sphinx
ALWAYS_LISTEN=false
WAKE_WORD=LAS
WAKE_WORD_SENSITIVITY=0.5

# ── Bluetooth ─────────────────────────────────────────────────────────────────
BLUETOOTH_ENABLED=true
BLUETOOTH_AUTO_CONNECT=true

# ── Telefonia (VoIP/SIP) ──────────────────────────────────────────────────────
TELEPHONY_ENABLED=true
SIP_SERVER=sip.exemplo.com.br
SIP_USER=ramal@dominio.com
SIP_PASSWORD=senha_sip

# ── Integrações ───────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=
TEAMS_WEBHOOK_URL=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
ALEXA_SKILL_ID=
GOOGLE_ASSISTANT_PROJECT_ID=

# ── Sincronização com Personal AI Web ─────────────────────────────────────────
PARENT_API_URL=http://localhost:8000
PARENT_API_KEY=
SYNC_ENABLED=true
SYNC_INTERVAL_SECONDS=30

# ── Auto-Melhoria ─────────────────────────────────────────────────────────────
SELF_MONITORING_ENABLED=true
SELF_IMPROVEMENT_ENABLED=true
AUTO_DEPLOY_PATCHES=false                  # true = aplica patches automaticamente (cuidado!)

# ── Celery Flower (monitoramento de workers) ──────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=admin_senha_aqui

# ── Nginx / Domínio (para deploy com HTTPS) ───────────────────────────────────
DOMAIN=seudominio.com.br
