# ═══════════════════════════════════════════════════════════════════════════════
# Personal AI Mobile — Configurações de Ambiente
# Copie para .env e preencha com seus valores reais
# ─────────────────────────────────────────────────────────────────────────────
# DEV (SQLite):  DATABASE_URL=sqlite+aiosqlite:///./data/mobile_ai.db
# PROD (PG):     DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development                              # development | production | testing
APP_PORT=8765
SECRET_KEY=mobile-ai-secret-change-in-prod-32chars!!
DOMAIN=localhost
CORS_ORIGINS=*
UVICORN_WORKERS=1                               # >1 requer PostgreSQL
DEBUG=false
LANGUAGE=pt-BR

# ── Banco de Dados ─────────────────────────────────────────────────────────────
# SQLite (desenvolvimento — padrão):
DATABASE_URL=sqlite+aiosqlite:///./data/mobile_ai.db

# PostgreSQL (produção — descomente e configure):
# DATABASE_URL=postgresql+asyncpg://ai_user:SENHA@localhost:5432/personal_ai
# POSTGRES_DB=personal_ai
# POSTGRES_USER=ai_user
# POSTGRES_PASSWORD=SENHA_FORTE_AQUI

# Pool de conexões PostgreSQL:
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# ── Redis ──────────────────────────────────────────────────────────────────────
# Deixe vazio para usar APScheduler (dev)
# Configure para usar Celery (prod):
# REDIS_URL=redis://:SENHA@redis:6379/0
# CELERY_BROKER_URL=redis://:SENHA@redis:6379/1
# CELERY_RESULT_BACKEND=redis://:SENHA@redis:6379/2
# REDIS_PASSWORD=SENHA_REDIS

# ── Provedores de IA ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GENSPARK_API_KEY=
DEFAULT_PROVIDER=openai                          # openai | anthropic | gemini | ollama
DEFAULT_MODEL=gpt-4o-mini
FALLBACK_PROVIDER=ollama
AUTONOMY_LEVEL=balanced                         # passive | balanced | proactive

# ── Ollama (LLM local para fallback offline) ────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_HOST=http://ollama:11434              # Docker Compose

# ── Voz (TTS / STT) ────────────────────────────────────────────────────────────
TTS_BACKEND=edge-tts                            # edge-tts | openai | piper
TTS_VOICE=pt-BR-FranciscaNeural
TTS_SPEED=1.0
STT_BACKEND=whisper                             # whisper | google | sphinx
ALWAYS_LISTEN=false
WAKE_WORD=LAS
WAKE_WORD_SENSITIVITY=0.5

# ── Bluetooth ──────────────────────────────────────────────────────────────────
BLUETOOTH_ENABLED=true
BLUETOOTH_SCAN_DURATION=10
BLUETOOTH_AUTO_CONNECT=true
# TRUSTED_DEVICES=["AA:BB:CC:DD:EE:FF"]        # JSON list de MACs confiáveis

# ── Telefonia ─────────────────────────────────────────────────────────────────
TELEPHONY_ENABLED=true
# SIP_SERVER=sip.provedor.com
# SIP_USER=usuario
# SIP_PASSWORD=senha
# GSM_MODEM_PORT=/dev/ttyUSB0

# ── Integração: Telegram ────────────────────────────────────────────────────────
# TELEGRAM_TOKEN=

# ── Integração: Alexa ──────────────────────────────────────────────────────────
# ALEXA_SKILL_ID=
# ALEXA_CLIENT_ID=
# ALEXA_CLIENT_SECRET=

# ── Integração: Google Assistant ───────────────────────────────────────────────
# GOOGLE_ASSISTANT_PROJECT_ID=

# ── Integração: WhatsApp Business ──────────────────────────────────────────────
# WHATSAPP_API_KEY=
# WHATSAPP_PHONE_ID=

# ── Integração: Microsoft (Outlook + Teams) ─────────────────────────────────────
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=
# OUTLOOK_TENANT_ID=
# TEAMS_WEBHOOK_URL=

# ── Integração: Spotify ────────────────────────────────────────────────────────
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# ── Sincronização com Personal AI Web ──────────────────────────────────────────
SYNC_ENABLED=true
PARENT_API_URL=http://localhost:8000             # URL da versão web (se existir)
PARENT_API_KEY=
SYNC_INTERVAL_SECONDS=30

# ── Modo Offline ───────────────────────────────────────────────────────────────
OFFLINE_MODE=false
OFFLINE_QUEUE_MAX=500
CONNECTIVITY_CHECK_URL=https://8.8.8.8

# ── Auto-Monitoramento e Auto-Melhoria ──────────────────────────────────────────
SELF_MONITORING_ENABLED=true
SELF_IMPROVEMENT_ENABLED=true
MONITORING_INTERVAL_SECONDS=60
IMPROVEMENT_CHECK_INTERVAL_HOURS=6
AUTO_DEPLOY_PATCHES=false                       # ATENÇÃO: Habilitação automática de patches
MAX_MEMORY_MB=512
MAX_CPU_PERCENT=80.0

# ── Fila de Jobs ──────────────────────────────────────────────────────────────
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT_SECONDS=300
JOB_RETRY_MAX=3

# ── Monitoramento de Produção ──────────────────────────────────────────────────
# FLOWER_USER=admin
# FLOWER_PASSWORD=
# PGADMIN_EMAIL=admin@example.com
# PGADMIN_PASSWORD=

# ── Celery Workers ─────────────────────────────────────────────────────────────
# CELERY_CONCURRENCY=4

# ── Dados (Docker Compose — volumes bind mount) ────────────────────────────────
# DATA_DIR=/opt/personal-ai/data
